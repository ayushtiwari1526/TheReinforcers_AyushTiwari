# ========================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (it's in .gitignore)

# HuggingFace Token (Required for AI Service)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# NewsAPI Key (Required for fetching news)
# Get from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Finnhub API Key (Required for stock market data)
# Get from: https://finnhub.io/register
FINNHUB_KEY=your_finnhub_key_here

# OpenAI API Key (Optional - for chatbot)
# Get from: https://platform.openai.com/api-keys
# Leave empty to use demo mode
OPENAI_API_KEY=sk_your_openai_key_here

# ========================================
# DEPLOYMENT URLs (For cloud deployment)
# ========================================

# Backend URL (Update after deploying to Render/Railway)
BACKEND_URL=http://localhost:8080

# AI Service URL (Update after deploying to Render/Railway)
AI_SERVICE_URL=http://localhost:5000

# Frontend URL (Update after deploying to Netlify/Vercel)
FRONTEND_URL=http://localhost:3000

# ========================================
# NOTES
# ========================================
# - HF_TOKEN must start with "hf_"
# - NEWSAPI_KEY is a 32-character hex string
# - FINNHUB_KEY is provided after registration
# - OPENAI_API_KEY starts with "sk-" (optional)
# - Keep your tokens secret - never share them!
