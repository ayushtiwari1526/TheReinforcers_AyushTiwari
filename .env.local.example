# Vercel Environment Variables Template
# Add these in Vercel Dashboard > Project Settings > Environment Variables

# Backend API URL (Update after deploying to Render)
NEXT_PUBLIC_BACKEND_URL=https://trading-signal-backend.onrender.com

# AI Service URL (Update after deploying to Render)
NEXT_PUBLIC_AI_SERVICE_URL=https://trading-ai-service.onrender.com

# Platform identifier
PLATFORM=vercel
